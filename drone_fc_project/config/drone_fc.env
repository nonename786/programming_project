# ==============================
# Drone Flight Controller Config
# USB debug + auto-start fly-basic version
# ==============================

DRONE_IBUS_PORT=/dev/ttyS1
DRONE_IBUS_BAUD=115200

DRONE_BT_PORT=/dev/ttyS2
DRONE_BT_BAUD=9600

DRONE_I2C_DEV=/dev/i2c-1
DRONE_MPU6050_ADDR=0x68

DRONE_MIN_PWM=1000
DRONE_IDLE_PWM=1050
DRONE_MAX_PWM=1550
DRONE_ESC_TEST_US=1300

DRONE_FLIGHT_THROTTLE_START_CH=1060
DRONE_FLIGHT_MOTOR_START_PWM=1220

DRONE_NO_BATTERY=1
DRONE_BATTERY_SCALE=7.5
DRONE_BAT_WARN=10.8
DRONE_BAT_LIMIT=10.2
DRONE_BAT_CRITICAL=9.6

DRONE_NO_BMP=1

DRONE_LOOP_HZ=100
DRONE_TELEMETRY_MS=200

DRONE_RC_MIN=1000
DRONE_RC_MID=1500
DRONE_RC_MAX=2000
DRONE_ARM_CH=5
DRONE_ARM_THRESHOLD=1500
DRONE_THROTTLE_LOW=1100

DRONE_MAX_SAFE_ANGLE=45

DRONE_MAX_ROLL_SET_DEG=10
DRONE_MAX_PITCH_SET_DEG=10
DRONE_MAX_YAW_RATE_DPS=45

DRONE_ROLL_KP=1.0
DRONE_ROLL_KI=0.0
DRONE_ROLL_KD=0.03
DRONE_ROLL_OUTPUT_LIMIT_US=160

DRONE_PITCH_KP=1.0
DRONE_PITCH_KI=0.0
DRONE_PITCH_KD=0.03
DRONE_PITCH_OUTPUT_LIMIT_US=160

DRONE_YAW_KP=0.4
DRONE_YAW_KI=0.0
DRONE_YAW_KD=0.0
DRONE_YAW_OUTPUT_LIMIT_US=80

DRONE_ROLL_MIX_SIGN=1
DRONE_PITCH_MIX_SIGN=1
DRONE_YAW_MIX_SIGN=1

DRONE_RC_MIX_LIMIT_US=100
DRONE_RC_YAW_MIX_LIMIT_US=80

DRONE_BOOT_DELAY=8
DRONE_USE_CHRT=0
DRONE_LOG_PATH=/root/drone_fc_telemetry.csv
